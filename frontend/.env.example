# Backend API base URL (no trailing slash). App routes requests to `{VITE_API_URL}/api/...`.
# Leave empty for a frontend-only Vercel demo (curated demo events).
# Example local: VITE_API_URL=http://localhost:5000
VITE_API_URL=

# When true, always use the demo event catalog (no listing API calls). Optional on Vercel
# if you already omit VITE_API_URL.
VITE_DEMO_MODE=true
