# Backend API — use either:
#   • Origin only: https://your-service.onrender.com  → app requests https://.../api/...
#   • Full API root: https://your-service.onrender.com/api  → same
# Leave empty for a frontend-only demo (curated events on Discover).
#
# Render (example):
# VITE_API_URL=https://lets-hang-b7tb.onrender.com/api
#
# Local backend:
# VITE_API_URL=http://localhost:5000

VITE_API_URL=

# true = always use demo events (ignore API for listings). Use false when VITE_API_URL is set.
VITE_DEMO_MODE=false
